---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--border-color)] mt-16">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-sm text-[var(--text-tertiary)]">
    <p class="font-mono text-xs">
      &copy; {year} Hiul·Book · Built with Astro
    </p>
    <div class="flex items-center gap-4 font-mono text-xs">
      <a href="/rss.xml" class="hover:text-[var(--accent)] transition-colors">RSS</a>
      <a href="https://github.com" target="_blank" rel="noopener" class="hover:text-[var(--accent)] transition-colors">GitHub</a>
    </div>
  </div>
</footer>
