---
import FormattedDate from './FormattedDate.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
  pinned?: boolean;
}

const { title, description, date, tags, slug, pinned = false } = Astro.props;
---

<article class="group relative rounded-lg border border-[var(--border-color)] p-5 hover:border-[var(--accent)] transition-colors bg-[var(--bg-primary)]">
  {pinned && (
    <span class="absolute -top-2 left-4 px-2 py-0.5 text-xs font-mono rounded bg-[var(--accent)] text-white">
      PINNED
    </span>
  )}
  <a href={`/posts/${slug}`} class="block">
    <h2 class="text-lg font-medium text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors">
      {title}
    </h2>
    <p class="mt-1 text-sm text-[var(--text-secondary)] line-clamp-2">{description}</p>
    <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-[var(--text-tertiary)] font-mono">
      <FormattedDate date={date} />
      {tags.length > 0 && (
        <span class="flex gap-1">
          {tags.slice(0, 3).map(tag => (
            <span class="px-1.5 py-0.5 rounded bg-[var(--bg-secondary)] text-[var(--text-secondary)]">#{tag}</span>
          ))}
        </span>
      )}
    </div>
  </a>
  <button
    class="fav-btn absolute top-3 right-3 p-1.5 rounded-md text-[var(--text-tertiary)] hover:text-[var(--accent)] transition-colors opacity-0 group-hover:opacity-100"
    data-slug={slug}
    data-title={title}
    aria-label="收藏"
  >
    <svg class="w-4 h-4 fav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
    </svg>
  </button>
</article>
