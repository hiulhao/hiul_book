---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="收藏" description="我收藏的文章">
  <section class="mb-8">
    <h1 class="text-2xl font-medium tracking-tight">
      <span class="text-[var(--accent)] font-mono">/</span> 收藏
    </h1>
    <p class="mt-1 text-sm text-[var(--text-secondary)] font-mono">
      你的本地收藏列表
    </p>
  </section>

  <div id="favorites-list" class="space-y-4">
    <div class="text-center py-16 text-[var(--text-tertiary)] font-mono text-sm">
      <p>暂无收藏文章</p>
      <p class="mt-2 text-xs">点击文章卡片右上角的书签图标即可收藏</p>
    </div>
  </div>
</BaseLayout>

<script>
  function renderFavorites() {
    const container = document.getElementById('favorites-list');
    if (!container) return;

    let favs: Array<{ slug: string; title: string }> = [];
    try {
      favs = JSON.parse(localStorage.getItem('devlog:favorites') || '[]');
    } catch {
      favs = [];
    }

    if (favs.length === 0) {
      container.innerHTML = `
        <div class="text-center py-16 text-[var(--text-tertiary)] font-mono text-sm">
          <p>暂无收藏文章</p>
          <p class="mt-2 text-xs">点击文章卡片右上角的书签图标即可收藏</p>
        </div>
      `;
      return;
    }

    container.innerHTML = favs.map(fav => `
      <div class="group flex items-center justify-between rounded-lg border border-[var(--border-color)] p-4 hover:border-[var(--accent)] transition-colors">
        <a href="/posts/${fav.slug}" class="flex-1">
          <p class="text-sm font-medium group-hover:text-[var(--accent)] transition-colors">${fav.title}</p>
          <p class="mt-1 text-xs text-[var(--text-tertiary)] font-mono">/posts/${fav.slug}</p>
        </a>
        <button
          class="remove-fav ml-3 p-2 rounded-md text-[var(--text-tertiary)] hover:text-[var(--accent)] hover:bg-[var(--bg-secondary)] transition-colors"
          data-slug="${fav.slug}"
          aria-label="移除收藏"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3" />
          </svg>
        </button>
      </div>
    `).join('');

    container.querySelectorAll('.remove-fav').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const slug = (e.currentTarget as HTMLElement).dataset.slug;
        if (!slug) return;
        const current = JSON.parse(localStorage.getItem('devlog:favorites') || '[]');
        const updated = current.filter((f: any) => f.slug !== slug);
        localStorage.setItem('devlog:favorites', JSON.stringify(updated));
        renderFavorites();
      });
    });
  }

  document.addEventListener('astro:page-load', renderFavorites);
  renderFavorites();
</script>
