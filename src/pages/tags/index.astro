---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const tagCount: Record<string, number> = {};
allPosts.forEach(post => {
  post.data.tags.forEach(tag => {
    tagCount[tag] = (tagCount[tag] || 0) + 1;
  });
});
const tags = Object.entries(tagCount).sort((a, b) => b[1] - a[1]);
const maxCount = Math.max(...tags.map(t => t[1]));
---

<BaseLayout title="标签" description="按标签浏览文章">
  <section class="mb-8">
    <h1 class="text-2xl font-medium tracking-tight">
      <span class="text-[var(--accent)] font-mono">/</span> 标签
    </h1>
    <p class="mt-1 text-sm text-[var(--text-secondary)] font-mono">
      {tags.length} tags
    </p>
  </section>

  <div class="flex flex-wrap gap-2">
    {tags.map(([tag, count]) => (
      <a
        href={`/tags/${tag}`}
        class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg border border-[var(--border-color)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors text-sm"
        style={`font-size: ${0.875 + (count / maxCount) * 0.25}rem`}
      >
        <span>#{tag}</span>
        <span class="text-xs text-[var(--text-tertiary)] font-mono">{count}</span>
      </a>
    ))}
  </div>

  {tags.length === 0 && (
    <div class="text-center py-16 text-[var(--text-tertiary)] font-mono text-sm">
      <p>No tags yet.</p>
    </div>
  )}
</BaseLayout>
